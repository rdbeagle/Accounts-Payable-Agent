# ── Email (IMAP) ──────────────────────────────────────────────
# Option A: Direct to Actionweb hosting
IMAP_HOST=mail.logisticconsultants.com
IMAP_PORT=993
IMAP_USER=orders@logisticconsultants.com
IMAP_PASSWORD=your_password_here
IMAP_MAILBOX=INBOX

# Option B: Gmail fallback — uncomment and swap values above
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=tsp.iws@gmail.com
# IMAP_PASSWORD=your_gmail_app_password

# ── Alert emails ───────────────────────────────────────────────
# Address that receives duplicate/mismatch alerts
ALERT_EMAIL=orders@logisticconsultants.com
# SMTP for sending alerts (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tsp.iws@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Storage ────────────────────────────────────────────────────
# Root folder where processed files are saved
STORAGE_ROOT=./data
